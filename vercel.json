{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/styles.css",
      "destination": "/styles.css"
    },
    {
      "source": "/dashboard.js",
      "destination": "/dashboard.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
